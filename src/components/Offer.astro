---
---

<section class="offer" id="offer">
  <div class="offer-inner">

    <div class="offer-header">
      <h2 class="display-headline offer-headline">
        Here's What You're Getting<br /><em>From the Bootcamp.</em>
      </h2>
    </div>

    <!-- Row 1: Includes + Bonuses -->
    <div class="offer-row-1">

      <div class="offer-box">
        <h3 class="offer-box-title">What's Included</h3>
        <ul class="offer-list">
          <li>
            <i class="fa-solid fa-graduation-cap"></i>
            <span class="offer-item-name">6 x Live Workshop Sessions</span>
            <span class="offer-item-val">Valued at £997</span>
          </li>
          <li>
            <i class="fa-solid fa-book-open"></i>
            <span class="offer-item-name">Lifetime access to a full step-by-step digital course</span>
            <span class="offer-item-val">Valued at £597</span>
          </li>
          <li>
            <i class="fa-solid fa-comments"></i>
            <span class="offer-item-name">90 Days membership of our private coaching group for 24/7 support</span>
            <span class="offer-item-val">Valued at £597</span>
          </li>
          <li>
            <i class="fa-solid fa-headset"></i>
            <span class="offer-item-name">90 Days access to twice-weekly live virtual group coaching calls</span>
            <span class="offer-item-val">Valued at £597</span>
          </li>
          <li>
            <i class="fa-solid fa-utensils"></i>
            <span class="offer-item-name">Lunch and Refreshments include in the day you choose</span>
            <span class="offer-item-val offer-item-val--free">Included</span>
          </li>
        </ul>
      </div>

      <div class="offer-box offer-box--bonus">
        <h3 class="offer-box-title offer-box-title--bonus">Bonuses</h3>
        <ul class="offer-list">
          <li>
            <i class="fa-solid fa-database"></i>
            <span class="offer-item-name">Database of past student masterclasses, preferred software, tricks, tips and shortcuts, including the EXACT tools I use</span>
            <span class="offer-item-val offer-item-val--bonus">Valued at £497</span>
          </li>
          <li>
            <i class="fa-solid fa-book-bookmark"></i>
            <span class="offer-item-name">Specially designed workbook to capture all your notes, data and progress</span>
            <span class="offer-item-val offer-item-val--bonus">Valued at £97</span>
          </li>
          <li>
            <i class="fa-solid fa-handshake"></i>
            <span class="offer-item-name">2024 Trade Fair Masterclass to help you 'wow' new suppliers, and have them queuing up to give you their products to sell for profit!</span>
            <span class="offer-item-val offer-item-val--bonus">Valued at £297</span>
          </li>
          <li>
            <i class="fa-solid fa-tag"></i>
            <span class="offer-item-name">25% discount off our Business Networking Event held on Saturday 2nd March (6.30pm onwards) at the same venue</span>
            <span class="offer-item-val offer-item-val--bonus">£297 Saved</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Row 2: Price — no container, just text -->
    <div class="offer-price">
      <span class="offer-price-was"><s>£3,976</s></span>
      <span class="offer-price-now">£997</span>
    </div>

    <!-- Trust -->
    <div class="offer-trust">
      <span><i class="fa-solid fa-infinity"></i> Lifetime Access to replays and resources</span>
      <span><i class="fa-solid fa-users"></i> Proven System taught to +1500 students</span>
      <span><i class="fa-solid fa-lock"></i> Secure Payment</span>
      <span><i class="fa-solid fa-headset"></i> 90 Days Aftercare support to monitor your progress</span>
    </div>

    <!-- Row 3: Two day boxes with payment options -->
    <div class="offer-pick-title">
      <h3 class="offer-pick-heading">Choose Your Day</h3>
      <p class="offer-pick-sub">Choose your preferred date from either Saturday 2nd March OR Sunday 3rd March<br />(don't choose both or you'll pay twice!)</p>
    </div>
    <div class="offer-row-3">

      <div class="offer-day-box offer-day-box--sat">
        <div class="offer-day-top">
          <p class="offer-day-label">Saturday</p>
          <p class="offer-day-date">2nd March · 9.30am – 3pm</p>
        </div>
        <div class="offer-day-payments">
          <a href="#" class="offer-pay-btn offer-pay-btn--full">
            <span class="offer-pay-amount">£997</span>
            <span class="offer-pay-desc">Pay in Full</span>
          </a>
          <a href="#" class="offer-pay-btn offer-pay-btn--split">
            <span class="offer-pay-amount">£500<span class="offer-pay-month">/month</span></span>
            <span class="offer-pay-desc">2 × Monthly Instalments</span>
          </a>
        </div>
      </div>

      <div class="offer-day-box offer-day-box--sun">
        <div class="offer-day-top">
          <p class="offer-day-label">Sunday</p>
          <p class="offer-day-date">3rd March · 9.30am – 3pm</p>
        </div>
        <div class="offer-day-payments">
          <a href="#" class="offer-pay-btn offer-pay-btn--full">
            <span class="offer-pay-amount">£997</span>
            <span class="offer-pay-desc">Pay in Full</span>
          </a>
          <a href="#" class="offer-pay-btn offer-pay-btn--split">
            <span class="offer-pay-amount">£500<span class="offer-pay-month">/month</span></span>
            <span class="offer-pay-desc">2 × Monthly Instalments</span>
          </a>
        </div>
      </div>

    </div>

    <!-- Payment method logos -->
    <div class="offer-payment-logos">
      <i class="fa-brands fa-cc-visa"></i>
      <i class="fa-brands fa-cc-mastercard"></i>
      <i class="fa-brands fa-cc-paypal"></i>
      <i class="fa-brands fa-cc-apple-pay"></i>
      <i class="fa-brands fa-cc-amazon-pay"></i>
      <i class="fa-brands fa-cc-amex"></i>
      <i class="fa-brands fa-google-pay"></i>
      <i class="fa-brands fa-klarna"></i>
    </div>

  </div>
</section>

<style>
  .offer {
    background: #FDFAF7;
    padding: 120px 0 100px;
  }

  .offer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* Header */
  .offer-header {
    max-width: 640px;
    margin-bottom: 64px;
  }

  .section-tag {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #D4A574;
  }

  .offer-headline {
    font-size: clamp(28px, 4vw, 52px);
    color: #1A1A1A;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .offer-headline em {
    color: #FF9900;
    font-style: italic;
  }

  .offer-sub {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    color: #666;
    line-height: 1.7;
  }

  /* Row 1 */
  .offer-row-1 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }

  .offer-box {
    background: #fff;
    border: 1.5px solid rgba(26, 26, 26, 0.15);
    padding: 32px;
  }

  .offer-box--bonus {
    border-color: rgba(212, 165, 116, 0.35);
  }

  .offer-box-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    font-style: italic;
    letter-spacing: 0;
    text-transform: none;
    color: #1A1A1A;
    opacity: 1;
    margin-bottom: 24px;
  }

  .offer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .offer-list li {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(26, 26, 26, 0.07);
  }

  .offer-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .offer-list i {
    font-size: 14px;
    color: #D4A574;
    width: 18px;
    flex-shrink: 0;
    text-align: center;
  }

  .offer-item-name {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: #1A1A1A;
    flex: 1;
  }

  .offer-item-val {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #D4A574;
    opacity: 1;
    font-weight: 600;
    white-space: nowrap;
  }

  .offer-item-val--free {
    color: #FF9900;
    opacity: 0.9;
  }

  .offer-item-val--bonus {
    color: #FF9900;
    opacity: 1;
    font-weight: 600;
  }

  /* Row 2: price text */
  .offer-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 16px;
    margin-bottom: 20px;
    padding: 0 4px;
  }

  .offer-payment-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 24px;
    margin-bottom: 28px;
  }

  .offer-payment-logos i {
    font-size: 36px;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .offer-payment-logos i:hover {
    opacity: 1;
  }

  .offer-payment-logos .fa-cc-visa      { color: #1A1F71; }
  .offer-payment-logos .fa-cc-mastercard { color: #FF5F00; }
  .offer-payment-logos .fa-cc-paypal    { color: #003087; }
  .offer-payment-logos .fa-cc-apple-pay { color: #000000; }
  .offer-payment-logos .fa-cc-amazon-pay { color: #FF9900; }
  .offer-payment-logos .fa-cc-amex      { color: #016FD0; }
  .offer-payment-logos .fa-google-pay   { color: #4285F4; }
  .offer-payment-logos .fa-klarna       { color: #FFB3C7; }

  .offer-price-was {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #1A1A1A;
    opacity: 0.6;
  }

  .offer-price-was s {
    text-decoration-thickness: 2px;
  }

  .offer-price-arrow {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    color: #D4A574;
    opacity: 0.5;
  }

  .offer-price-now {
    font-family: 'Inter', sans-serif;
    font-size: 64px;
    font-weight: 900;
    color: #1A1A1A;
    line-height: 1;
  }

  /* Pick title */
  .offer-pick-title {
    text-align: center;
    margin-bottom: 28px;
  }

  .offer-pick-heading {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 8px;
  }

  .offer-pick-sub {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #1A1A1A;
    opacity: 0.55;
    text-align: center;
    line-height: 1.7;
  }

  /* Row 3: day boxes */
  .offer-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }

  .offer-day-box {
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* Saturday: orange bg, black text */
  .offer-day-box--sat { background: #E8A830; }
  .offer-day-box--sat .offer-day-label { color: #1A1A1A; }
  .offer-day-box--sat .offer-day-date  { color: #1A1A1A; opacity: 0.55; }

  /* Sunday: black bg, white/orange text */
  .offer-day-box--sun { background: #1A1A1A; }
  .offer-day-box--sun .offer-day-label { color: #E8A830; }
  .offer-day-box--sun .offer-day-date  { color: #fff; opacity: 0.45; }

  .offer-day-top {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .offer-day-label {
    font-family: 'Lora', serif;
    font-size: 38px;
    font-weight: 600;
    font-style: italic;
    line-height: 1;
  }

  .offer-day-date {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .offer-day-payments {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .offer-pay-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    text-decoration: none;
    border-radius: 4px;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .offer-pay-btn:hover { transform: translateY(-2px); opacity: 0.9; }

  /* Saturday buttons: black fill / black outline */
  .offer-day-box--sat .offer-pay-btn--full               { background: #1A1A1A; box-shadow: 0 4px 0 #000; }
  .offer-day-box--sat .offer-pay-btn--split              { border: 2px solid rgba(26,26,26,0.3); }
  .offer-day-box--sat .offer-pay-amount                  { color: #fff; }
  .offer-day-box--sat .offer-pay-btn--split .offer-pay-amount { color: #1A1A1A; }
  .offer-day-box--sat .offer-pay-month                   { color: #fff; }
  .offer-day-box--sat .offer-pay-btn--split .offer-pay-month  { color: #1A1A1A; }
  .offer-day-box--sat .offer-pay-desc                    { color: #fff; opacity: 0.7; }
  .offer-day-box--sat .offer-pay-btn--split .offer-pay-desc   { color: #1A1A1A; opacity: 0.6; }

  /* Sunday buttons: orange fill / orange outline */
  .offer-day-box--sun .offer-pay-btn--full               { background: #E8A830; box-shadow: 0 4px 0 #A06C00; }
  .offer-day-box--sun .offer-pay-btn--split              { border: 2px solid rgba(232,168,48,0.4); }
  .offer-day-box--sun .offer-pay-amount                  { color: #fff; }
  .offer-day-box--sun .offer-pay-btn--split .offer-pay-amount { color: #E8A830; }
  .offer-day-box--sun .offer-pay-month                   { color: #fff; }
  .offer-day-box--sun .offer-pay-btn--split .offer-pay-month  { color: #E8A830; }
  .offer-day-box--sun .offer-pay-desc                    { color: #fff; opacity: 0.7; }
  .offer-day-box--sun .offer-pay-btn--split .offer-pay-desc   { color: #E8A830; opacity: 0.8; }

  .offer-pay-amount {
    font-family: 'Inter', sans-serif;
    font-size: 24px;
    font-weight: 900;
    line-height: 1;
  }

  .offer-pay-month {
    font-size: 13px;
    font-weight: 500;
    opacity: 0.75;
  }

  .offer-pay-desc {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Trust */
  .offer-trust {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .offer-trust span {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1A1A1A;
    opacity: 0.7;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .offer-trust i {
    font-size: 20px;
    color: #FF9900;
    opacity: 1;
  }

  @media (max-width: 800px) {
    .offer { padding: 72px 0 64px; }
    .offer-inner { padding: 0 24px; }
    .offer-row-1 { grid-template-columns: 1fr; }
    .offer-row-3 { grid-template-columns: 1fr; }
    .offer-price { flex-wrap: wrap; gap: 8px; }
    .offer-price-now { font-size: 48px; }
    .offer-payment-logos { flex-wrap: wrap; gap: 12px; }
    .offer-payment-logos i { font-size: 28px; }
    .offer-header { margin-bottom: 40px; }
  }
</style>
