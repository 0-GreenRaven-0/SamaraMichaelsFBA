      quote: 'SubhanAllah, they really want you to be successful. They want you to learn everything that they can give.',
    },
    {
      src: 'videos/7.mp4',
      name: 'Brother Salman and Wife',
      location: 'Bristol',
      tag: 'Complete beginner',
      stars: 5,
      quote: "The biggest success at the moment is we already got a few lines which are repetitive selling — Alhamdullilah we're doing well",
    },
    {
      src: 'videos/8.mp4',
