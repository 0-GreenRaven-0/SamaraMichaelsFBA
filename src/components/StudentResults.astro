---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const resultImages = import.meta.glob<{ default: ImageMetadata }>('../assets/Results/*.{png,webp}', { eager: true });
function getResultImg(n: number): ImageMetadata {
  const ext = n >= 15 ? 'webp' : 'png';
  return resultImages[`../assets/Results/${n}.${ext}`]!.default;
}
---
<section class="sr" id="student-results">
  <div class="sr-inner">
    <div class="sr-header reveal">
      <h2 class="display-headline sr-headline">
        Dms from our <em>2000 Graduates</em><br />
      </h2>
      <p class="sr-sub">These are screenshots and messages we receive on a daily basis from our students</p>
    </div>

    <div class="sr-masonry">
      {Array.from({length: 12}, (_, i) => i + 1).map((n, i) => (
        <div class="sr-item" style={`animation-delay: ${(i % 4) * 0.08}s`} data-sr-item>
          <Image
            src={getResultImg(n)}
            alt={`Student result ${n}`}
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <div class="sr-cta reveal">
      <a href="#offer" class="btn-primary">Join the Next Success Story</a>
      <p class="sr-urgency">Doors close March 1st — Seats are limited</p>
    </div>
  </div>
</section>

<style>
  .sr {
    background: var(--color-off-white);
    padding: 130px 0 110px;
    position: relative;
    overflow: hidden;
  }

  .sr::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-gold), var(--color-amazon), var(--color-gold));
    opacity: 0.5;
  }

  .sr-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .sr-header {
    text-align: center;
    margin-bottom: 72px;
  }

  .sr-headline {
    font-size: clamp(30px, 4vw, 56px);
    color: var(--color-near-black);
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .sr-headline em {
    color: var(--color-amazon);
    font-style: italic;
  }

  .sr-sub {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--color-near-black);
    opacity: 0.45;
    letter-spacing: 0.03em;
  }

  /* Masonry via CSS columns — images display at natural height, no cropping */
  .sr-masonry {
    columns: 4;
    column-gap: 12px;
  }

  .sr-item {
    break-inside: avoid;
    margin-bottom: 12px;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(26, 26, 26, 0.1);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease;
  }

  .sr-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sr-item:hover {
    box-shadow: 0 12px 40px rgba(26, 26, 26, 0.18);
    z-index: 1;
    position: relative;
  }

  .sr-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .sr-item:hover img {
    transform: scale(1.03);
  }

  .sr-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    margin-top: 72px;
  }

  .sr-urgency {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #E03030;
    opacity: 1;
  }

  @media (max-width: 1000px) {
    .sr { padding: 72px 0 64px; }
    .sr-inner { padding: 0 24px; }
    .sr-masonry { columns: 3; }
    .sr-header { margin-bottom: 48px; }
  }

  @media (max-width: 600px) {
    .sr-masonry { columns: 2; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const items = document.querySelectorAll('[data-sr-item]');

  items.forEach((item, i) => {
    gsap.fromTo(item,
      { opacity: 0, y: 28 },
      {
        opacity: 1, y: 0,
        duration: 0.6,
        delay: (i % 4) * 0.08,
        ease: 'power2.out',
        scrollTrigger: { trigger: item, start: 'top 90%' }
      }
    );
  });
</script>
