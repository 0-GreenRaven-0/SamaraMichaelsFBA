---
import { Image } from 'astro:assets';
import idilImg from '../assets/13103154_1600440698560idil.webp';
import mohammedImg from '../assets/13097178_1600419333271mohammed.webp';
import mahwishImg from '../assets/13097297_1600419752086mahwish.webp';

const testimonials = [
  {
    name: 'Idil',
    tag: 'Graduated Student',
    quote: "Working with Samara to get my business going was the best thing I could of done. Samara's training is easy to understand and she shares a lot of off-the-record info regarding selling that helped me stay motivated. I now totally see the value in getting help from a pro.",
    stars: 5,
    img: idilImg,
  },
  {
    name: 'Mohammed',
    tag: 'Graduated Student',
    quote: "Samara really does want students to succeed and will share very on point data and tips. Rarely do you find somebody so prepared to share business data to this level.  She has got integrity and values which were important characteristics when choosing a mentor.",
    stars: 5,
    img: mohammedImg,
  },
  {
    name: 'Yasmin',
    tag: 'Graduated Student',
    quote: "I had previously dabbled in selling weight loss supplements but it didn't have a consistent income. I worked with Samara and she helped me with literally everything. I'm making 10-20 sales on average a day and my business is growing quickly.",
    stars: 5,
    img: mahwishImg,
  },
];
---

<section class="wt" id="written-testimonials">
  <div class="wt-inner">
    <div class="wt-grid">
      {testimonials.map((t) => (
        <div class="wt-card wt-card-stagger">
          <p class="wt-quote">"{t.quote}"</p>
          <div class="wt-author">
            <Image src={t.img} alt={t.name} class="wt-avatar" loading="lazy" />
            <div>
              <p class="wt-name">{t.name}</p>
              <p class="wt-meta">{t.tag}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .wt {
    background: #1A1A1A;
    padding: 110px 0 100px;
  }

  .wt-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .wt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 64px;
  }

  .wt-card-stagger {
    opacity: 0;
  }

  .wt-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .wt-quote {
    font-family: 'Lora', serif;
    font-size: 19px;
    font-style: italic;
    line-height: 1.8;
    color: #fff;
    opacity: 0.75;
    flex: 1;
    margin-bottom: 28px;
  }

  .wt-author {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .wt-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
    flex-shrink: 0;
  }

  .wt-name {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
  }

  .wt-meta {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #fff;
    opacity: 0.4;
  }

  @media (max-width: 1000px) {
    .wt { padding: 72px 0 64px; }
    .wt-inner { padding: 0 24px; }
    .wt-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll('.wt-card-stagger');
  if (cards.length) {
    gsap.fromTo(cards,
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0,
        duration: 0.85,
        stagger: { amount: 0.4, from: 'start' },
        ease: 'power2.out',
        scrollTrigger: { trigger: '.wt-grid', start: 'top 84%' }
      }
    );
  }
</script>
