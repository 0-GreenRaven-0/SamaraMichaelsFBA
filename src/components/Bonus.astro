---
import { Image } from 'astro:assets';
import bookImg from '../assets/book.png';
---
<section class="bonus" id="bonus">
  <div class="bonus-inner">

    <!-- Title -->
    <div class="bonus-header reveal">
      <p class="section-tag bonus-tag">Exclusive Bonus</p>
      <h2 class="display-headline bonus-headline">
        Your Professionally Designed Manual<br /><em>to further Guide in your FBA Journey.</em>
      </h2>
      <p class="bonus-sub">You're not walking away empty handed.</p>
    </div>

    <div class="bonus-row">
      <!-- Image -->
      <div class="bonus-visual reveal-scale">
        <div class="bonus-book-wrap relative">
          <Image src={bookImg} alt="FBA Bootcamp Workbook" class="bonus-book" loading="lazy" />
        </div>
      </div>

      <!-- Content -->
      <div class="bonus-content">
      <p class="body-lora bonus-para reveal">
        That's right! We put together this Workbook to make sure you have a clear step-by-step plan to follow to further scale your FBA Business which will be shot straight to your Inbox after the bootcamp!
      </p>

      <p class="body-lora bonus-para reveal">
        This isn't your typical course of bundled knowledge you can easily find anywhere for free on the internet, this is a <strong>completed FBA manual</strong> you can return to again and again whenever support is needed.
      </p>

      <div class="bonus-features reveal">
        <div class="bonus-feature">
          <i class="fa-solid fa-check bonus-check"></i>
          <span>Step-by-step plan to follow post-bootcamp</span>
        </div>
        <div class="bonus-feature">
          <i class="fa-solid fa-check bonus-check"></i>
          <span>Space to capture notes, data &amp; progress during sessions</span>
        </div>
        <div class="bonus-feature">
          <i class="fa-solid fa-check bonus-check"></i>
          <span>Yours to keep and reference for life</span>
        </div>
        <div class="bonus-feature">
          <i class="fa-solid fa-check bonus-check"></i>
          <span>Delivered to your inbox after the bootcamp</span>
        </div>
      </div>

      <div class="bonus-cta reveal">
        <a href="#offer" class="btn-primary">Claim My Free Workbook</a>
        <p class="bonus-urgency">Doors close March 1st — Seats are limited</p>
      </div>
    </div>
    </div><!-- closes bonus-row -->

  </div>
</section>

<style>
  .bonus {
    background: var(--color-near-black);
    padding: 130px 0 110px;
    position: relative;
    overflow: hidden;
  }

  .bonus::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    opacity: 0.2;
  }

  .bonus-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 60px;
    position: relative;
  }

  /* Header */
  .bonus-header {
    margin-bottom: 72px;
    text-align: center;
  }

  .bonus-tag {
    color: var(--color-gold);
    margin-bottom: 16px;
  }

  .bonus-headline {
    font-size: clamp(28px, 3.8vw, 52px);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 18px;
  }

  .bonus-headline em {
    color: var(--color-gold);
    font-style: italic;
  }

  .bonus-sub {
    font-family: 'Lora', serif;
    font-size: 17px;
    font-style: italic;
    color: #fff;
    opacity: 0.45;
  }

  /* Row layout */
  .bonus-row {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 72px;
    align-items: center;
  }

  /* Image + shine */
  .bonus-visual {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bonus-book-wrap {
    position: relative;
    width: 440px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bonus-book {
    position: relative;
    z-index: 1;
    width: 100%;
    display: block;
    filter: drop-shadow(0 32px 64px rgba(0,0,0,0.7));
  }

  /* Badge */
  .bonus-badge {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .bonus-badge-value {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: line-through;
    text-decoration-color: rgba(212,165,116,0.4);
    line-height: 1;
  }

  .bonus-badge-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0.4;
  }

  /* Content */
  .bonus-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    width: 100%;
  }

  .bonus-para {
    color: #fff;
    font-size: 16px;
    opacity: 0.65;
    line-height: 1.8;
    text-align: left;
  }

  .bonus-para strong {
    color: #fff;
    opacity: 1;
    font-weight: 700;
  }

  /* Features */
  .bonus-features {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    padding: 28px 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .bonus-feature {
    display: flex;
    gap: 14px;
    align-items: center;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: #fff;
    opacity: 0.75;
    line-height: 1.5;
    text-align: left;
  }

  .bonus-check {
    color: var(--color-gold);
    font-size: 12px;
    flex-shrink: 0;
  }

  /* Value */
  .bonus-value {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .bonus-value-crossed {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    opacity: 0.25;
    text-decoration: line-through;
  }

  .bonus-value-free {
    font-family: 'Inter', sans-serif;
    font-size: 40px;
    font-weight: 900;
    color: var(--color-gold);
    line-height: 1;
  }

  .bonus-value-note {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0.35;
    align-self: center;
  }

  /* CTA */
  .bonus-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .bonus-urgency {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #E03030;
    opacity: 1;
  }

  @media (max-width: 800px) {
    .bonus { padding: 72px 0 64px; }
    .bonus-inner { padding: 0 24px; }
    .bonus-header { margin-bottom: 48px; }
    .bonus-row { grid-template-columns: 1fr; gap: 48px; }
    .bonus-content { align-items: center; }
    .bonus-para { text-align: center; }
    .bonus-book-wrap { width: 260px; }
  }
</style>

