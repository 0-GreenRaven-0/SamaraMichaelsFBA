---
import { Image } from 'astro:assets';
import samaraPortrait from '../assets/samaraportrait.png';
import mahjPatel from '../assets/23384883_1634570852pT2MahjPatel.webp';
import faheema from '../assets/28739188_1655139582302Faheema.webp';
import karina from '../assets/23384926_16345709749rFkarina2.webp';
---
<section class="samara " id="about-samara">
  <div class="samara-inner">


    <div class="samara-founder">
      <div class="samara-portrait-wrap reveal-scale">
        <div class="samara-portrait-card bg-[#FDF8F2]!">
          <div class="samara-portrait-title">
            <span class="samara-portrait-eyebrow">Meet</span>
            <h2 class="samara-portrait-name">Samara Michael.</h2>
          </div>
          <Image src={samaraPortrait} alt="Samara Michael" loading="lazy" class="samara-portrait-img" />
        </div>

        <div class="sphere-orbit-container">
          {[
            { num: "2000+", label: "Students Coached",  pos: "top: 0%;   left: 38%;" },
            { num: "£5M+",  label: "Revenue Generated", pos: "top: 33%;  left: 0%;"  },
            { num: "6+",    label: "Years Coaching",    pos: "top: 65%;  left: 35%;" },
          ].map((s, i) => (
            <div class="sphere-item" style={`${s.pos} animation-delay: ${-i * 1.8}s`}>
              <div class="sphere-scene">
                <div class="sphere-ball">
                  <div class="sphere-ring ring-h"></div>
                  <div class="sphere-ring ring-v"></div>
                  <div class="sphere-ring ring-d"></div>
                </div>
                <div class="sphere-text">
                  <span class="sphere-num">{s.num}</span>
                  <span class="sphere-label">{s.label}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="samara-founder-copy">
        <p class="body-lora samara-para reveal">
          I'm Samara! — Founder of the FBA Kickstarter Academy, Business Coach
          and Owner of Lake House Huddersfield.
        </p>

        <p class="body-lora samara-para reveal">
         Being a trustworthy, straight-talking Yorkshire lass — I'm honoured you've felt a pull in my direction! Years ago, I was stuck in a stressful council job that was robbing me of the time to experience and live my life. I knew I had to do something if I ever wished to escape this reality.
        </p>

        <p class="body-lora samara-para reveal">
         I was always interested in the world of business — ever since I was 7 years old when I started my very first business selling homemade perfumes made from flowers and tap water. (Made only 1 sale — and that was my mum...)
        </p>

        <p class="body-lora samara-para reveal">
         So I began exploring different business models across the internet until I discovered Amazon FBA — poured all my focus into it, went through lots of hardship and trials — and hit 7-Figures.
        </p>

        <p class="body-lora samara-para reveal">
        Many people around me started asking how I did it and if I could teach them. So when I saw how much of a difference this could make in people's lives and financial wellbeing — I decided to start an online Academy to help as many folks as possible sell on Amazon like me.
        </p>

        <p class="body-lora samara-para reveal">
          Today I've coached over <strong>2000 people</strong> to successfully build a business selling on Amazon — people who wanted to buy back their time and earn their freedom.
        </p>

        <p class="body-lora samara-para reveal">
          So while gurus are selling you "courses" packed with outdated and recycled info — I'm offering you my hand to walk you through the <strong>real skills</strong> that every successful FBA seller must have.
          <em>(Apologies, gurus...)</em>
        </p>
      </div>
    </div>

    <!-- Team -->
    <div class="samara-team-header reveal">
      <h3 class="samara-team-title">All That With the Help of My Awesome Team of Friendly Experts.</h3>
    </div>

    <div class="samara-team">
      <div class="samara-member reveal-left">
        <div class="samara-member-avatar">
          <Image src={mahjPatel} alt="Mahj Patel" loading="lazy" />
        </div>
        <div class="samara-member-info">
          <p class="samara-member-name">Mahj Patel</p>
          <p class="samara-member-role">Support & Strategy Mentor</p>
          <p class="body-lora samara-member-bio">
            Mahj achieved in ONE year what it took me FIVE years to perfect. She's pure Amazon FBA rocket fuel.
            Friendly, approachable and supportive, she's like the Amazon FBA auntie you always wanted in your back pocket. You'll feel honoured to work with her!
          </p>
        </div>
      </div>

      <div class="samara-member reveal-left" style="transition-delay: 0.1s">
        <div class="samara-member-avatar">
          <Image src={faheema} alt="Faheema Patel" loading="lazy" />
        </div>
        <div class="samara-member-info">
          <p class="samara-member-name">Faheema Patel</p>
          <p class="samara-member-role">Community Manager</p>
          <p class="body-lora samara-member-bio">
            A qualified teacher and mentor, Faheema is our newest recruit and graduate of the Kickstarter Programme.
            Already a multiple six-figure seller — she's full of wisdom and gems with a heart of gold masha'Allah! Stuck? Pop a post on our Community Platform and Faheema will reply in MORE detail than you could have wished for AND in twice the speed!
          </p>
        </div>
      </div>

      <div class="samara-member reveal-left" style="transition-delay: 0.2s">
        <div class="samara-member-avatar">
          <Image src={karina} alt="Kristine (Karina)" loading="lazy" />
        </div>
        <div class="samara-member-info">
          <p class="samara-member-name">Kristine (Karina)</p>
          <p class="samara-member-role">Former Amazon Trainer</p>
          <p class="body-lora samara-member-bio">
            Kristine is the jewel in our crown. Smart, polite, and funny — she knows Amazon Policy like the back of her hand. I headhunted her from Amazon's Seller Support after all! She'll lead the session on Amazon's rules and policies and, with her expertise, you are SURE to feel safe and savvy as you step into your expert Amazon FBA zone.
          </p>
        </div>
      </div>
    </div>

    <div class="samara-cta reveal">
      <a href="#offer" class="btn-primary">Grab Your Seat & Meet Us at the Bootcamp!</a>
      <p class="samara-cta-urgency">Doors close March 1st — Seats are limited</p>
    </div>
  </div>
</section>

<style>
  .samara {
    background: #FDF8F2;
    padding: 130px 0 110px;
    position: relative;
    overflow: hidden;
  }

  .samara-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    position: relative;
  }

  .samara-num {
    top: -40px;
    right: 40px;
    color: rgba(26, 26, 26, 0.07);
  }

  /* Founder layout — centered single column */
  .samara-founder {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 100px;
    gap: 0;
  }

  /* Portrait card */
  .samara-portrait-card {
    background: #FDF8F2 !important;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px 48px 0;
    box-shadow: 0 24px 80px rgba(26, 26, 26, 0.12);
    overflow: visible;
  }

  .samara-portrait-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-bottom: 32px;
  }

  .samara-portrait-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .samara-portrait-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 700;
    font-style: italic;
    color: var(--color-near-black);
    line-height: 1.1;
  }

  .samara-portrait-img {
    width: 100%;
    display: block;
    object-fit: contain;
  }

  /* Portrait wrap — relative anchor for the spheres */
  .samara-portrait-wrap {
    position: relative;
    width: 100%;
    max-width: 620px;
    margin-bottom: 52px;
    overflow: visible;
  }

  /* Orbit container — absolutely anchored to Samara's hand */
  .sphere-orbit-container {
    position: absolute;
    width: 180px;
    height: 200px;
    left: 15%;
    bottom: 15%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 10;
  }

  /* Each sphere floats in its fixed position */
  .sphere-item {
    position: absolute;
    width: 85px;
    height: 85px;
    animation: float 5s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px);   }
    50%       { transform: translateY(-16px); }
  }

  .sphere-scene {
    position: relative;
    width: 85px;
    height: 85px;
    perspective: 250px;
  }

  .sphere-ball {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 50%,
      #e8b87a 0%,
      #c4822a 45%,
      #7a4d10 78%,
      #4a2d08 100%
    );
    box-shadow:
      inset -6px -6px 14px rgba(0, 0, 0, 0.3),
      0 4px 14px rgba(212, 165, 116, 0.2);
    transform-style: preserve-3d;
  }

  .sphere-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(212, 165, 116, 0.5);
  }

  .ring-h {
    animation: spin-h 5s linear infinite;
  }

  .ring-v {
    animation: spin-v 7s linear infinite reverse;
    border-color: rgba(212, 165, 116, 0.35);
  }

  .ring-d {
    animation: spin-h 11s linear infinite;
    border-color: rgba(212, 165, 116, 0.2);
    inset: -14px;
  }

  @keyframes spin-h {
    from { transform: rotateX(72deg) rotateZ(0deg); }
    to   { transform: rotateX(72deg) rotateZ(360deg); }
  }

  @keyframes spin-v {
    from { transform: rotateY(72deg) rotateZ(0deg); }
    to   { transform: rotateY(72deg) rotateZ(360deg); }
  }

  .sphere-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 0 8px;
  }

  .sphere-num {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 800;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    line-height: 1;
  }

  .sphere-label {
    font-family: 'Inter', sans-serif;
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
    text-align: center;
    line-height: 1.3;
  }

  .samara-founder-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 720px;
    width: 100%;
  }

  .samara-creds {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .samara-cred {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-near-black);
    opacity: 0.5;
  }

  .samara-cred-sep {
    color: var(--color-gold);
    opacity: 0.5;
  }

  .samara-para {
    color: #444;
    font-size: 16px;
    line-height: 1.8;
    text-align: left;
  }

  .samara-para strong {
    color: var(--color-near-black);
    font-weight: 700;
  }

  .samara-para em {
    color: #777;
  }

  /* Team */
  .samara-team-header {
    margin-bottom: 48px;
  }

  .samara-team-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 2.8vw, 36px);
    font-weight: 700;
    color: var(--color-near-black);
    margin-top: 12px;
    max-width: 680px;
  }

  .samara-team {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 72px;
  }

  .samara-member {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(26, 26, 26, 0.18);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px 32px 36px;
  }

  .samara-member-avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-gold);
    box-shadow: 0 0 0 6px rgba(212, 165, 116, 0.12);
    margin-bottom: 28px;
    flex-shrink: 0;
  }

  .samara-member-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .samara-member-info {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .samara-member-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--color-near-black);
    margin-bottom: 6px;
  }

  .samara-member-role {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    opacity: 0.85;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
    width: 100%;
    text-align: center;
  }

  .samara-member-bio {
    font-size: 14px;
    color: #555;
    line-height: 1.75;
  }

  /* CTA */
  .samara-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }

  .samara-cta-urgency {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #E03030;
    opacity: 1;
  }

  @media (max-width: 1000px) {
    .samara { padding: 72px 0 64px; }
    .samara-portrait-card { max-width: 100%; padding: 32px 24px 0; }
    .sphere-orbit-container { transform: translate(-50%, -50%) scale(0.65); }
    .samara-founder { margin-bottom: 60px; }
    .samara-team { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .samara-member { padding: 28px 20px 28px; }
    .samara-inner { padding: 0 24px; }
    .samara-header { margin-bottom: 48px; }
  }

  @media (max-width: 600px) {
    .samara-team { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .sphere-orbit-container {
      left: 16%;
      bottom: 5%;
      transform: translate(-50%, -50%) scale(0.8);
    }
  }
</style>

