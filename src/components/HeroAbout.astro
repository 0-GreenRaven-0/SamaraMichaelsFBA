---
---
<div class="ha-wrap">

<!-- ═══ HERO ═══ -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-content">

      <p class="section-tag hero-tag reveal">Join our Live In-Person Training as we teach you...</p>
      <div class="gold-rule reveal" style="margin: 16px auto 24px;"></div>

      <div class="hero-main-row">
        <h1 class="display-headline hero-headline" id="hero-headline">
          <span class="hero-line">How to Build a</span>
          <span class="hero-line hero-line--italic">Profitable FBA Business</span>
          <span class="hero-line">as your Halal</span>
          <span class="hero-line hero-line--accent">Source of Income</span>
          <span class="hero-line hero-line--sub">& Achieve Freedom to Spend</span>
          <span class="hero-line hero-line--sub">Time with your Family.</span>
        </h1>
        <div class="hero-visual">
          <img src={import.meta.env.BASE_URL + "sm1.png"} alt="Samara Michael — FBA Bootcamp" class="hero-img" />
        </div>
      </div>

      <div class="hero-proof reveal">
        <div class="hero-proof-item">
          <span class="hero-proof-num">+2000</span>
          <span class="hero-proof-label">Students Taught</span>
        </div>
        <div class="hero-proof-divider"></div>
        <div class="hero-proof-item">
          <span class="hero-proof-num">6</span>
          <span class="hero-proof-label">Years Teaching FBA</span>
        </div>
        <div class="hero-proof-divider"></div>
        <div class="hero-proof-item">
          <span class="hero-proof-num">£5M+</span>
          <span class="hero-proof-label">Revenue Generated</span>
        </div>
      </div>

      <p class="hero-subtext reveal">
        For Complete Newbies with no prior experience looking for halal income from home!
      </p>

      <div class="hero-ctas reveal">
        <a href="#offer" class="btn-primary">Reserve My Seat Now!</a>
        <span class="hero-seats"><i class="fa-solid fa-bolt"></i> Doors close March 1st — Seats are limited</span>
      </div>
    </div>

    <div class="hero-scroll-hint" id="hero-scroll-hint">
      <span class="hero-scroll-text">Scroll</span>
      <div class="hero-scroll-mouse">
        <span class="hero-scroll-dot"></span>
      </div>
    </div>
  </div>
</section>

<!-- ═══ ABOUT FBA ═══ -->
<section class="about-fba" id="about-fba" style="clip-path: circle(0% at 120% 50%);">

  <div class="abt-inner">

    <!-- ── Act I: What is FBA? ── -->
    <div class="abt-act abt-act--1">
      <div class="abt-copy reveal">
        <h2 class="display-headline abt-headline">
          What is <em>FBA?</em>
        </h2>
        <p class="body-lora abt-para">
          <strong>FBA (Fulfilment By Amazon)</strong> is a work-from-home business model that allows you to tap into Amazon's wide logistic networks — which means you create your seller account on Amazon, ship your products to Amazon's warehouses, and they will take care of order fulfilment like packaging and delivering to your customers when you receive an order, removing the annoying bits of managing a business.
        </p>
        <p class="body-lora abt-para">
          So all you have to do is come up with a product that flies off the shelves like hot pakoras!
        </p>
      </div>

      <div class="abt-visual reveal-scale">
        <div class="abt-img-wrap">
          <img src={import.meta.env.BASE_URL + "pic1.webp"} alt="The UK eCommerce opportunity" class="abt-img" />
        </div>
      </div>
    </div>

    <!-- ── Turning point ── -->
    <div class="abt-pivot reveal">
      <span class="abt-pivot-mark" aria-hidden="true">&ldquo;</span>
      <p class="display-headline abt-pivot-text">
        So what better time<br />to start FBA than <em>NOW?</em>
      </p>
    </div>

    <!-- ── Act II: The Opportunity ── -->
    <div class="abt-act abt-act--2">
      <div class="abt-visual reveal-scale">
        <div class="abt-img-wrap abt-img-wrap--2">
          <img src={import.meta.env.BASE_URL + "pic2.webp"} alt="Building your FBA business" class="abt-img" />
        </div>
      </div>

      <div class="abt-copy reveal">
        <p class="body-lora abt-para">
          Online shopping has come a long way from being a novelty to becoming the backbone of modern retail.
        </p>
        <p class="body-lora abt-para">
          In the UK specifically, over 90% of people online have ditched the high streets in favour of armchair ordering, making the UK the <strong>third largest eCommerce market in the world</strong> after China and the US.
        </p>
        <p class="body-lora abt-para">
          Almost 50p out of every £1 spent on shopping in the UK happens online — so there's never been a better time to start FBA Selling than Now!
        </p>
      </div>
    </div>

  </div>
</section>

</div>{/* /.ha-wrap */}

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: linear-gradient(135deg, #fff 0%, #fff 40%, #FFF0D0 72%, #FFD080 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 48px 60px 60px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-content {
    width: 100%;
    text-align: center;
  }

  .hero-tag {
    display: block;
  }

  .hero-main-row {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 36px;
    text-align: left;
  }

  .hero-visual {
    flex-shrink: 0;
    width: 460px;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-tag {
    color: #B8720A;
    font-weight: 600;
  }

  .hero-headline {
    font-size: clamp(32px, 4.8vw, 68px);
    color: var(--color-near-black);
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .hero-line {
    display: block;
    overflow: hidden;
    line-height: 1.12;
  }

  .hero-line--italic {
    font-style: italic;
    color: var(--color-gold);
  }

  .hero-line--accent {
    color: var(--color-amazon);
  }

  .hero-line--sub {
    font-size: 0.58em;
    font-weight: 400;
    color: #888;
    margin-top: 4px;
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .hero-proof-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero-proof-num {
    font-family: 'Inter', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
  }

  .hero-proof-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #444;
    opacity: 1;
  }

  .hero-proof-divider {
    width: 1px;
    height: 40px;
    background: rgba(26, 26, 26, 0.15);
  }

  .hero-subtext {
    font-size: 16px;
    color: #333;
    margin-bottom: 40px;
    opacity: 1;
    font-style: italic;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .hero-seats {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: #E03030;
    opacity: 1;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 40px;
    left: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }

  .hero-scroll-text {
    font-family: 'Inter', sans-serif;
    font-size: 8px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(212, 165, 116, 0.6);
  }

  .hero-scroll-mouse {
    width: 22px;
    height: 36px;
    border-radius: 11px;
    border: 1.5px solid rgba(212, 165, 116, 0.55);
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .hero-scroll-dot {
    width: 3px;
    height: 6px;
    border-radius: 2px;
    background: var(--color-gold);
    animation: scroll-dot 2s ease-in-out infinite;
  }

  @keyframes scroll-dot {
    0%   { transform: translateY(0);    opacity: 1; }
    60%  { transform: translateY(12px); opacity: 0; }
    61%  { transform: translateY(0);    opacity: 0; }
    100% { transform: translateY(0);    opacity: 1; }
  }

  @media (max-width: 768px) {
    .hero-main-row { flex-direction: column; }
    .hero-visual { width: 100%; max-width: 320px; align-self: center; }
    .hero-headline { text-align: center; }
    .hero-inner { padding: 80px 24px 60px; }
    .hero-proof-divider { display: none; }
    .hero-proof { gap: 20px; justify-content: center; }
    .hero-proof-item { align-items: center; }
    .hero-proof-num { font-size: 22px; }
    .hero-proof-label { font-size: 9px; }
    .hero-scroll-hint { left: 24px; }
    .hero-ctas { flex-direction: column; align-items: center; gap: 16px; }
    .hero-seats { font-size: 10px; }
  }

  /* ── Shared container ── */
  .ha-wrap {
    position: relative;
  }

  /* ── About FBA shell ── */
  .about-fba {
    background: var(--color-dark-brown);
    padding: 0;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    min-height: 100vh;
    overflow: hidden;
    clip-path: circle(0% at 120% 50%);
    z-index: 10;
  }

  .abt-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 100px 60px 120px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* override gold-rule colour for light bg */
  .about-fba .gold-rule { background: rgba(26, 26, 26, 0.2); }

  /* ── Shared tag ── */
  .abt-tag { color: #1A1A1A; opacity: 0.5; }

  /* ── Act layout ── */
  .abt-act {
    display: grid;
    gap: 64px;
    align-items: center;
    padding: 72px 0;
  }

  .abt-act--1 {
    grid-template-columns: 1fr 420px;
    border-bottom: 1px solid rgba(26, 26, 26, 0.12);
  }

  .abt-act--2 {
    grid-template-columns: 380px 1fr;
    padding-bottom: 0;
  }

  /* ── Copy side ── */
  .abt-copy { display: flex; flex-direction: column; }

  .abt-headline {
    font-size: clamp(30px, 3.8vw, 52px);
    color: #1A1A1A;
    margin-bottom: 36px;
    line-height: 1.1;
  }

  .abt-headline em {
    color: #fff;
    font-style: italic;
  }

  .abt-para {
    color: rgba(255, 255, 255, 0.82);
    font-size: 17px;
    margin-bottom: 18px;
  }

  .abt-para:last-child { margin-bottom: 0; }

  .abt-para strong {
    color: #fff;
    font-weight: 600;
  }

  /* ── Visual side ── */
  .abt-visual { position: relative; }

  .abt-img-wrap {
    position: relative;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.18);
  }

  .abt-img-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(26, 26, 26, 0.1);
    z-index: 2;
    pointer-events: none;
  }

  .abt-img-wrap--2 { border-left: 3px solid rgba(26, 26, 26, 0.25); }

  .abt-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Pivot quote ── */
  .abt-pivot {
    text-align: center;
    padding: 80px 0 72px;
    position: relative;
    border-bottom: 1px solid rgba(26, 26, 26, 0.12);
  }

  .abt-pivot-mark {
    font-family: 'Playfair Display', serif;
    font-size: 180px;
    line-height: 0.6;
    color: rgba(26, 26, 26, 0.06);
    display: block;
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    user-select: none;
    pointer-events: none;
  }

  .abt-pivot-text {
    font-size: clamp(28px, 4.5vw, 64px);
    color: #1A1A1A;
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.15;
  }

  .abt-pivot-text em {
    color: #fff;
    font-style: italic;
  }

  /* ── Callout (act 2) ── */
  .abt-callout {
    border-left: 3px solid rgba(26, 26, 26, 0.25);
    padding: 20px 28px;
    background: rgba(26, 26, 26, 0.05);
    margin-top: 24px;
  }

  .abt-callout-text {
    font-family: 'Lora', serif;
    font-size: 17px;
    font-style: italic;
    color: #1A1A1A;
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .abt-inner { padding: 72px 32px 96px; }

    .abt-act--1,
    .abt-act--2 {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 0;
    }

    .abt-act--2 .abt-visual { order: -1; }

    .abt-stats { flex-direction: column; gap: 32px; padding: 40px 0; }
    .abt-stat-item { padding: 0; }
    .abt-stat-divider { width: 56px; height: 1px; }

    .abt-pivot { padding: 56px 0 48px; }
    .abt-pivot-mark { font-size: 120px; }
  }

  @media (max-width: 600px) {
    .abt-inner { padding: 56px 20px 72px; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Hero ──

  const lines = document.querySelectorAll('.hero-line');
  lines.forEach((line) => {
    const inner = document.createElement('span');
    inner.style.display = 'block';
    inner.innerHTML = (line as HTMLElement).innerHTML;
    line.innerHTML = '';
    line.appendChild(inner);
    gsap.from(inner, {
      yPercent: 110,
      duration: 1,
      ease: 'power3.out',
      delay: 0.1,
    });
  });

  document.querySelectorAll('.hero .reveal').forEach((el, i) => {
    gsap.to(el, { opacity: 1, y: 0, duration: 0.9, delay: 0.6 + i * 0.15, ease: 'power2.out' });
  });


  gsap.to('#hero-scroll-hint', { opacity: 1, duration: 1, delay: 2 });

  ScrollTrigger.create({
    trigger: '#hero',
    start: 'top+=100 top',
    onEnter: () => gsap.to('#hero-scroll-hint', { opacity: 0, duration: 0.4 }),
  });

  // ── About FBA ──

  // ── Hero → About FBA transition ──

  function buildClipPaths() {
    const aboutEl = document.getElementById('about-fba') as HTMLElement;
    const elH = Math.max(aboutEl.scrollHeight, aboutEl.offsetHeight, 1);
    const originY = ((window.innerHeight / 2 / elH) * 100).toFixed(2);
    return {
      hidden: `circle(0% at 120% ${originY}%)`,
      full:   `circle(150% at 120% ${originY}%)`,
    };
  }

  const clips = buildClipPaths();
  gsap.set('#about-fba', { clipPath: clips.hidden });

  function layoutHaWrap() {
    const heroEl   = document.getElementById('hero') as HTMLElement;
    const aboutEl  = document.getElementById('about-fba') as HTMLElement;
    const haWrap   = document.querySelector<HTMLElement>('.ha-wrap')!;
    const heroH    = heroEl.offsetHeight;
    const aboutTop = Math.max(0, heroH - window.innerHeight);
    gsap.set(aboutEl, { top: aboutTop });
    haWrap.style.minHeight = (aboutTop + aboutEl.scrollHeight) + 'px';
  }
  layoutHaWrap();
  window.addEventListener('resize', () => { layoutHaWrap(); ScrollTrigger.refresh(); });

  gsap.timeline({
    scrollTrigger: {
      trigger: '#hero',
      start: 'bottom bottom',
      end: '+=200%',
      scrub: 1.5,
      pin: '.ha-wrap',
    },
  })
    .to('#about-fba', {
      clipPath: clips.full,
      ease: 'power2.inOut',
      duration: 1,
    }, 0);
</script>
