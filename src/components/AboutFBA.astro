---
---
<section class="about-fba" id="about-fba">
  <div class="about-fba-inner">
    <span class="editorial-number about-num">01</span>

    <div class="about-grid">
      <div class="about-left">
        <p class="section-tag reveal" style="color: #1A1A1A;">What is FBA?</p>
        <div class="gold-rule reveal" style="margin: 16px 0 28px;"></div>
        <h2 class="display-headline about-headline reveal">
          The UK's <em>£100 Billion</em><br />eCommerce Opportunity<br />is Wide Open.
        </h2>
        <div class="about-rule-group reveal">
          <div class="about-stat">
            <span class="about-stat-num" data-count="90">0</span><span class="about-stat-suffix">%</span>
            <p class="about-stat-label">of UK consumers shop online</p>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">50p</span>
            <p class="about-stat-label">of every £1 spent is spent online in the UK</p>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">#3</span>
            <p class="about-stat-label">UK is the 3rd largest eCommerce market in the world</p>
          </div>
        </div>
      </div>

      <div class="about-right">
        <div class="about-copy">
          <p class="body-lora reveal">
            Online shopping has come a long way from being a novelty to becoming the backbone of modern retail.
          </p>
          <p class="body-lora reveal">
            In the UK specifically, over 90% of people online have ditched the high streets in favour of armchair ordering, making the UK the <strong>third largest eCommerce market in the world</strong> after China and the US.
          </p>
          <p class="body-lora reveal">
            Almost 50p out of every £1 spent on shopping in the UK happens online.
          </p>
          <p class="body-lora reveal about-question">
            So what better time to start FBA than <strong>NOW?</strong>
          </p>
          <div class="about-fba-box reveal">
            <p class="about-fba-box-title">What is FBA?</p>
            <p class="body-lora">
              For those of you who have never heard of <strong>FBA (Fulfilment By Amazon)</strong> — it's one of the best biz models that allows you to work from your own surroundings, giving you access to Amazon's massive storage and logistics network.
            </p>
            <p class="body-lora" style="margin-top: 16px;">
              Which means you outsource the annoying parts of running a business — handling orders, packing, posting — while all you have to do is <strong>SHOW UP with a product that flies off the shelves like hot pakoras!</strong>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-fba {
    background: var(--color-dark-brown);
    padding: 120px 0 140px;
    position: relative;
    overflow: hidden;
  }

  .about-fba-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    position: relative;
  }

  .about-num {
    top: -20px;
    left: 40px;
  }

  /* Override gold-rule for amber background */
  .about-fba .gold-rule {
    background: rgba(26, 26, 26, 0.3);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .about-left {}

  .about-headline {
    font-size: clamp(32px, 4vw, 56px);
    color: #1A1A1A;
    margin-bottom: 48px;
    line-height: 1.1;
  }

  .about-headline em {
    color: #fff;
    font-style: italic;
  }

  .about-rule-group {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .about-stat {
    display: flex;
    align-items: baseline;
    gap: 0;
    flex-wrap: wrap;
  }

  .about-stat-num {
    font-family: 'Inter', sans-serif;
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1;
    display: inline-block;
  }

  .about-stat-suffix {
    font-family: 'Inter', sans-serif;
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1;
  }

  .about-stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1A1A1A;
    opacity: 0.6;
    width: 100%;
    margin-top: 6px;
  }

  .about-right {}

  .about-copy {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-copy .body-lora {
    color: #1A1A1A;
    font-size: 17px;
    opacity: 0.85;
  }

  .about-copy .body-lora strong {
    color: #1A1A1A;
    font-weight: 600;
    opacity: 1;
  }

  .about-question {
    font-size: 22px !important;
    opacity: 1 !important;
    color: #1A1A1A !important;
    font-style: italic;
  }

  .about-fba-box {
    border-left: 3px solid rgba(26,26,26,0.25);
    padding: 24px 28px;
    background: rgba(26, 26, 26, 0.06);
    margin-top: 8px;
  }

  .about-fba-box-title {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #1A1A1A;
    margin-bottom: 12px;
  }

  .about-fba-box .body-lora {
    font-size: 15px !important;
  }

  @media (max-width: 900px) {
    .about-fba { padding: 72px 0 64px; }
    .about-grid { grid-template-columns: 1fr; gap: 48px; }
    .about-fba-inner { padding: 0 24px; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Counter animation — use a plain object to avoid DOM innerText read-back issues
  document.querySelectorAll('.about-stat-num[data-count]').forEach((el) => {
    const htmlEl = el as HTMLElement;
    const target = parseInt(htmlEl.dataset.count!);
    ScrollTrigger.create({
      trigger: htmlEl,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2,
          ease: 'power1.inOut',
          onUpdate() { htmlEl.textContent = Math.round(obj.val).toString(); }
        });
      }
    });
  });
</script>
