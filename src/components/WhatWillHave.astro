---
---
<section class="wwh" id="what-will-have">
  <div class="wwh-bg"></div>
  <div class="wwh-overlay"></div>

  <div class="wwh-inner">
    <div class="wwh-content">
  
      <div class="wwh-body">
        <p class="wwh-statement reveal">
          Alhamdulillah For everything I have achieved today. Had I not discovered Amazon FBA,
          I'd still be stuck in a job that was robbing me of my life, my time, and my freedom.
        </p>

        <p class="wwh-statement reveal">
          But it wasn't easy — it took a lot of trial and error to get to where I am today.
        </p>

        <p class="wwh-statement wwh-statement--strong reveal">
          I knew how much of a difference this could make in the lives and financial wellbeing of others —
          so I decided to teach as many people as possible the same path that led me here.
        </p>

        <div class="wwh-purpose reveal">
          <p class="wwh-purpose-text">
            And that's the exact purpose of this bootcamp — to help <em>YOU</em> build a business
            that buys back your time, build something great on your own terms, and achieve financial
            freedom like me and the many others who followed my teachings.
          </p>
        </div>
      </div>

      <div class="wwh-cta reveal">
        <a href="#offer" class="btn-primary">Enroll Me in the Bootcamp!</a>
        <p class="wwh-urgency">Doors close March 1st — Seats are limited</p>
      </div>
    </div>

  </div>

  <div class="wwh-image reveal-scale">
    <img src={import.meta.env.BASE_URL + "sm3.png"} alt="Samara Michael" loading="lazy" />
  </div>
</section>

<style>
  .wwh {
    position: relative;
    background: var(--color-off-white);
    padding: 130px 0 0;
    overflow: hidden;
  }

  /* Diagonal accent */
  .wwh::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 30%;
    height: 100%;
    background: var(--color-beige);
    clip-path: polygon(25% 0%, 100% 0%, 100% 100%, 0% 100%);
    z-index: 0;
  }

  .wwh-bg,
  .wwh-overlay {
    display: none;
  }

  .wwh-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    position: relative;
    z-index: 1;
  }

  .wwh-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 65%;
    padding-bottom: 110px;
  }

  .wwh-tag {
    color: var(--color-gold);
  }

  .wwh-arabic {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 72px);
    font-weight: 900;
    font-style: italic;
    color: var(--color-near-black);
    line-height: 1;
    margin-bottom: 36px;
    opacity: 0.15;
  }

  .wwh-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }

  .wwh-statement {
    font-family: 'Lora', serif;
    font-size: clamp(16px, 2vw, 20px);
    color: var(--color-near-black);
    opacity: 0.75;
    line-height: 1.75;
  }

  .wwh-statement--strong {
    opacity: 0.9;
    font-weight: 600;
  }

  .wwh-purpose {
    border-left: 4px solid var(--color-amazon);
    padding: 24px 32px;
    background: rgba(255, 153, 0, 0.05);
    margin-top: 8px;
  }

  .wwh-purpose-text {
    font-family: 'Lora', serif;
    font-size: clamp(18px, 2.2vw, 24px);
    font-style: italic;
    color: var(--color-near-black);
    line-height: 1.55;
  }

  .wwh-purpose-text em {
    color: var(--color-amazon);
    font-style: italic;
  }

  .wwh-pillars {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 44px;
    flex-wrap: wrap;
    gap: 0;
  }

  .wwh-pillar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 0;
  }

  .wwh-pillar-icon {
    font-size: 20px;
  }

  .wwh-pillar-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-near-black);
    opacity: 0.6;
  }

  .wwh-pillar-sep {
    width: 1px;
    height: 24px;
    background: rgba(26, 26, 26, 0.15);
    margin: 0 24px;
  }

  .wwh-cta {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
  }

  .wwh-urgency {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #E03030;
    opacity: 1;
  }

  /* Image — sits exactly over the beige area, same clip-path */
  .wwh-image {
    position: absolute;
    top: 0;
    right: 0;
    width: 30%;
    height: 100%;
    clip-path: polygon(25% 0%, 100% 0%, 100% 100%, 0% 100%);
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .wwh-image img {
    width: auto;
    max-width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 1000px) {
    .wwh { padding: 72px 0 64px; }
    .wwh-inner { grid-template-columns: 1fr; gap: 48px; padding: 0 24px; }
    .wwh::after { display: none; }
    .wwh-image { display: none; }
    .wwh-content { max-width: 100%; padding-bottom: 0; }
    .wwh-pillar-sep { display: none; }
    .wwh-pillars { gap: 8px; }
    .wwh-pillar { padding: 10px 0; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Animate arabic text opacity
  const arabic = document.querySelector('.wwh-arabic');
  if (arabic) {
    gsap.fromTo(arabic,
      { opacity: 0 },
      {
        opacity: 0.15, duration: 1.4, ease: 'power1.out',
        scrollTrigger: { trigger: arabic, start: 'top 88%' }
      }
    );
  }
</script>
